# =============================================================================
# .env.production.example — LIUX Sign
# =============================================================================
# Reference values for the production deployment of LIUX Sign.
#
# DO NOT commit a real .env.production with secrets to git.
# Configure these directly in your hosting provider's environment variables UI
# (Vercel / Render / Railway / Fly / Cloudflare Pages, etc.) or in a runtime
# secret manager.
#
# Variables not listed here keep the same values as .env (database, S3 bucket,
# Resend API key, etc.) — copy them as-is and only override what's below.
# =============================================================================

# ---- Public URL of the app (the one users see) -------------------------------
# Used by:
#  - Email templates (signing links, "view document" buttons).
#  - QR codes embedded in signing certificates.
#  - Cookies / session domain.
NEXT_PUBLIC_WEBAPP_URL="https://sign.liux.eco"

# ---- Internal URL ------------------------------------------------------------
# In most setups this matches the public URL. Use a private hostname only if
# your platform exposes a different internal endpoint for server-to-server.
NEXT_PRIVATE_INTERNAL_WEBAPP_URL="https://sign.liux.eco"

# ---- Sender of outgoing emails -----------------------------------------------
# Reuse the same Resend config as dev. Verify the domain `liux.eco` in Resend
# and ensure DNS records (SPF, DKIM, DMARC) are set.
NEXT_PRIVATE_SMTP_TRANSPORT="resend"
NEXT_PRIVATE_SMTP_FROM_NAME="LIUX Sign"
NEXT_PRIVATE_SMTP_FROM_ADDRESS="no-reply@liux.eco"
NEXT_PRIVATE_RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"

# ---- Database ---------------------------------------------------------------
# Same Supabase connection as dev (or a separate prod project, recommended).
NEXT_PRIVATE_DATABASE_URL="postgresql://..."
NEXT_PRIVATE_DIRECT_DATABASE_URL="postgresql://..."

# ---- File storage (Supabase Storage S3-compatible) --------------------------
NEXT_PUBLIC_UPLOAD_TRANSPORT="s3"
NEXT_PRIVATE_UPLOAD_ENDPOINT="https://<your-supabase-project>.storage.supabase.co/storage/v1/s3"
NEXT_PRIVATE_UPLOAD_REGION="eu-west-3"
NEXT_PRIVATE_UPLOAD_BUCKET="liux-sign-docs"
NEXT_PRIVATE_UPLOAD_FORCE_PATH_STYLE="true"
NEXT_PRIVATE_UPLOAD_ACCESS_KEY_ID="<rotate-and-regenerate>"
NEXT_PRIVATE_UPLOAD_SECRET_ACCESS_KEY="<rotate-and-regenerate>"

# ---- Auth / signup -----------------------------------------------------------
# Public signup is disabled — only admins can create users from the panel.
NEXT_PUBLIC_DISABLE_SIGNUP=true

# ---- Redis (jobs queue) ------------------------------------------------------
# Required for background jobs (email sending, document sealing, etc.).
# Use a managed Redis like Upstash (free tier suffices) or a Cloudflare/Render
# add-on. Replace with your production Redis URL.
NEXT_PRIVATE_REDIS_URL="rediss://default:<password>@<host>:<port>"

# ---- Optional: Cloudflare Turnstile captcha ----------------------------------
# Recommended in production to mitigate brute-force/abuse on signin.
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x4AAAAAAAxxxxxxxxxxxxxx"
# NEXT_PRIVATE_TURNSTILE_SECRET_KEY="0x4AAAAAAAyyyyyyyyyyyyyy"
